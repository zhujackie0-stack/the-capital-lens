<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= sectionName %> — in-depth research and analysis from The Capital Lens.">
  <title><%= sectionName %> — The Capital Lens</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="container main-content">
    <div class="section-page-header">
      <h1><%= sectionName %></h1>
      <p class="section-description">
        <% if (category === 'equity') { %>
          Deep-dive analysis on public equities — valuations, earnings, and investment theses.
        <% } else { %>
          Research on bonds, credit markets, interest rates, and fixed-income strategies.
        <% } %>
      </p>
    </div>

    <% if (articles.length === 0) { %>
      <div class="empty-state-large">
        <p>No articles in this section yet.</p>
        <p class="empty-hint">Check back soon — new research is published regularly.</p>
      </div>
    <% } else { %>
      <div class="article-list">
        <% articles.forEach(function(a) { %>
          <a href="/article/<%= a.id %>" class="article-row">
            <div class="article-row-content">
              <h3 class="row-title"><%= a.title %></h3>
              <div class="row-meta">
                <span class="row-author"><%= a.author %></span>
                <span class="row-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              </div>
            </div>
            <span class="row-arrow">→</span>
          </a>
        <% }); %>
      </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
