<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Independent equity and fixed-income research, career guides — rigorous analysis for finance professionals and students.">
  <title>Home — The Capital Lens</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <section class="hero">
    <div class="hero-content">
      <h1>The Capital Lens</h1>
      <p class="hero-tagline">Independent Research & Career Insights for Finance</p>
    </div>
  </section>

  <!-- Meet the Founders -->
  <section class="founders-section">
    <div class="container">
      <h2 class="founders-heading">Meet the Founders</h2>
      <div class="founders-grid">

        <!-- Jackie Zhu -->
        <div class="founder-card">
          <div class="founder-photo-wrapper">
            <img src="/images/jackie-zhu.jpg" alt="Jackie Zhu" class="founder-photo">
          </div>
          <h3 class="founder-name">Jackie Zhu</h3>
          <p class="founder-role">Co-Founder</p>
          <p class="founder-tagline">Statistics + Finance · WashU | Investment Management</p>
          <p class="founder-bio">
            My goal is to help students, aspiring investors, and early-career professionals better understand financial markets, develop investing knowledge, and navigate careers in finance.
          </p>
          <p class="founder-bio">
            Hop on a call with me if you want to talk about the markets, Finance, or even your favorite sports teams / artists!
          </p>
          <a href="mailto:zhujackie0@gmail.com?subject=Request%20for%20Coffee%20Chat&body=Hi%20Jackie%2C%20this%20is%20(Please%20Fill%20out%20your%20name).%0A%0AI'm%20(Type%20in%20your%20background)%0A%0AWould%20you%20be%20free%20at%20(Time%20you%20are%20available)%20to%20hop%20on%20a%20call%20with%20me%3F%0A%0AThank%20you!%20Looking%20forward%20to%20it." class="founder-cta">
            Network with me!
          </a>
        </div>

        <!-- Chase Mason -->
        <div class="founder-card">
          <div class="founder-photo-wrapper">
            <img src="/images/chase-mason.jpg" alt="Chase Mason" class="founder-photo">
          </div>
          <h3 class="founder-name">Chase Mason</h3>
          <p class="founder-role">Co-Founder</p>
          <p class="founder-tagline">Accounting Analytics · Baruch College | Equity Research</p>
          <p class="founder-bio">
            I write because I have a passion for introducing new audiences to what's happening in the world of Finance and AI.
          </p>
          <p class="founder-bio">
            Follow on Instagram <a href="https://www.instagram.com/chase.mason.a.mason" target="_blank" class="founder-social">@chase.mason.a.mason</a> or reach out via the button below.
          </p>
          <a href="mailto:Masonchase310@gmail.com?subject=Request%20for%20Coffee%20Chat&body=Hi%20Chase%2C%20this%20is%20(Please%20Fill%20out%20your%20name).%0A%0AI'm%20(Type%20in%20your%20background)%0A%0AWould%20you%20be%20free%20at%20(Time%20you%20are%20available)%20to%20hop%20on%20a%20call%20with%20me%3F%0A%0AThank%20you!%20Looking%20forward%20to%20it." class="founder-cta">
            Network with me!
          </a>
        </div>

      </div>
    </div>
  </section>

  <main class="container main-content">
    <!-- Tab Navigation -->
    <div class="tab-nav" id="tabNav">
      <button class="tab-btn active" data-tab="investment-research" id="tab-investment-research">
        <span class="tab-icon">📊</span>
        Investment Research
      </button>
      <button class="tab-btn" data-tab="career-paths" id="tab-career-paths">
        <span class="tab-icon">🎯</span>
        Career Paths in Finance
      </button>
    </div>

    <!-- Investment Research Tab -->
    <div class="tab-panel active" id="panel-investment-research">
      <section class="home-sections">
        <div class="section-block">
          <div class="section-header">
            <h2>Equity Research</h2>
            <a href="/section/equity" class="view-all">View All →</a>
          </div>
          <% if (equityArticles.length === 0) { %>
            <p class="empty-state">No articles published yet.</p>
          <% } else { %>
            <div class="article-grid">
              <% equityArticles.forEach(function(a) { %>
                <a href="/article/<%= a.id %>" class="article-card">
                  <span class="card-category equity">Equity</span>
                  <h3 class="card-title"><%= a.title %></h3>
                  <div class="card-meta">
                    <span class="card-author"><%= a.author %></span>
                    <span class="card-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>

        <div class="section-block">
          <div class="section-header">
            <h2>Fixed-Income Research</h2>
            <a href="/section/fixed-income" class="view-all">View All →</a>
          </div>
          <% if (fiArticles.length === 0) { %>
            <p class="empty-state">No articles published yet.</p>
          <% } else { %>
            <div class="article-grid">
              <% fiArticles.forEach(function(a) { %>
                <a href="/article/<%= a.id %>" class="article-card">
                  <span class="card-category fi">Fixed-Income</span>
                  <h3 class="card-title"><%= a.title %></h3>
                  <div class="card-meta">
                    <span class="card-author"><%= a.author %></span>
                    <span class="card-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>
      </section>
    </div>

    <!-- Career Paths Tab -->
    <div class="tab-panel" id="panel-career-paths">
      <section class="home-sections">
        <div class="section-block">
          <div class="section-header">
            <h2>Career Paths in Finance</h2>
            <a href="/section/career-paths" class="view-all">View All →</a>
          </div>
          <% if (careerArticles.length === 0) { %>
            <p class="empty-state">No articles published yet.</p>
          <% } else { %>
            <div class="article-grid">
              <% careerArticles.forEach(function(a) { %>
                <a href="/article/<%= a.id %>" class="article-card">
                  <span class="card-category career">Career</span>
                  <h3 class="card-title"><%= a.title %></h3>
                  <div class="card-meta">
                    <span class="card-author"><%= a.author %></span>
                    <span class="card-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Tab switching
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;

        // Update buttons
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Update panels
        tabPanels.forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + target).classList.add('active');
      });
    });
  </script>
</body>
</html>
