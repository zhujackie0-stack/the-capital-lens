<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Independent equity and fixed-income research — rigorous analysis for finance professionals and students.">
  <title>Home — The Capital Lens</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <section class="hero">
    <div class="hero-content">
      <h1>The Capital Lens</h1>
      <p class="hero-tagline">Independent Equity & Fixed-Income Research</p>
      <p class="hero-subtitle">Rigorous analysis for finance professionals, investors, and students seeking deeper market insight.</p>
    </div>
  </section>

  <main class="container main-content">
    <section class="home-sections">
      <div class="section-block">
        <div class="section-header">
          <h2>Equity Research</h2>
          <a href="/section/equity" class="view-all">View All →</a>
        </div>
        <% if (equityArticles.length === 0) { %>
          <p class="empty-state">No articles published yet.</p>
        <% } else { %>
          <div class="article-grid">
            <% equityArticles.forEach(function(a) { %>
              <a href="/article/<%= a.id %>" class="article-card">
                <span class="card-category equity">Equity</span>
                <h3 class="card-title"><%= a.title %></h3>
                <p class="card-excerpt"><%= a.excerpt %>...</p>
                <div class="card-meta">
                  <span class="card-author"><%= a.author %></span>
                  <span class="card-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>

      <div class="section-block">
        <div class="section-header">
          <h2>Fixed-Income Research</h2>
          <a href="/section/fixed-income" class="view-all">View All →</a>
        </div>
        <% if (fiArticles.length === 0) { %>
          <p class="empty-state">No articles published yet.</p>
        <% } else { %>
          <div class="article-grid">
            <% fiArticles.forEach(function(a) { %>
              <a href="/article/<%= a.id %>" class="article-card">
                <span class="card-category fi">Fixed-Income</span>
                <h3 class="card-title"><%= a.title %></h3>
                <p class="card-excerpt"><%= a.excerpt %>...</p>
                <div class="card-meta">
                  <span class="card-author"><%= a.author %></span>
                  <span class="card-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
